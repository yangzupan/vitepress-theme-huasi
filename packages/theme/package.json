{
  "name": "vitepress-theme-huasi",
  "version": "0.0.1",
  "description": "一个花点心思的 Vitepress 主题",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.mjs",
      "require": "./dist/config/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "dev:docs": "vitepress dev docs",
    "build:docs": "vitepress build docs",
    "preview:docs": "vitepress preview docs",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@vue/tsconfig": "^0.9.1",
    "typescript": "^5.3.3",
    "unbuild": "^3.0.0",
    "vitepress": "catalog:",
    "vue": "^3.4.15"
  },
  "peerDependencies": {
    "vitepress": "catalog:",
    "vue": "^3.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.2"
}